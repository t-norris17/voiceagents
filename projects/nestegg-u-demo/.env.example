# Env template for the demo mock backend (poc-mock-tools.js).
# Copy to .env.local for local testing, OR set these in the Vercel project's
# Settings → Environment Variables. NEVER commit real values — .env.local is gitignored.

# Resend API key (server-side only — this is the secret you just generated).
RESEND_API_KEY=

# Sender address. Use a verified domain sender, or leave the Resend onboarding
# sender for a quick demo (works immediately, no DNS setup).
RESEND_FROM=onboarding@resend.dev

# The "email on file" the reset link lands in — the presenter's OWN inbox.
DEMO_EMAIL=

# Deployed URL of the mock reset page (reset-page/index.html).
# e.g. https://<your-scratch-project>.vercel.app/reset
RESET_PAGE_URL=

# NOTE: the specialist transfer number (DEMO_TRANSFER_NUMBER) is NOT set here —
# it's configured on the transfer tool in the ElevenLabs dashboard, not the mock.
